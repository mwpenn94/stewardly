# ===========================================================================
# Stewardly v3 — environment template
# ---------------------------------------------------------------------------
# Copy to .env and populate. The same variable names are used in the Manus
# Cloud panel under Settings → Secrets. The migration runbook
# (migrations/runbook.md) describes how to copy values across.
# ===========================================================================

# ---- Foundation core (from manus-next-app) --------------------------------
NODE_ENV=development
PORT=3000
DATABASE_URL=mysql://user:password@host:3306/stewardly
JWT_SECRET=changeme-32-or-more-random-bytes
VITE_APP_ID=stewardly
OAUTH_SERVER_URL=
OWNER_OPEN_ID=
OWNER_NAME=
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=
VITE_FRONTEND_FORGE_API_URL=

# ---- Connector OAuth (foundation) -----------------------------------------
CONNECTOR_GITHUB_CLIENT_ID=
CONNECTOR_GITHUB_CLIENT_SECRET=
CONNECTOR_GOOGLE_CLIENT_ID=
CONNECTOR_GOOGLE_CLIENT_SECRET=
CONNECTOR_NOTION_CLIENT_ID=
CONNECTOR_NOTION_CLIENT_SECRET=
CONNECTOR_SLACK_CLIENT_ID=
CONNECTOR_SLACK_CLIENT_SECRET=
CONNECTOR_MICROSOFT_365_CLIENT_ID=
CONNECTOR_MICROSOFT_365_CLIENT_SECRET=

# Legacy aliases (foundation falls back to these if the CONNECTOR_* aren't set)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ---- Stripe (foundation) ---------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
VITE_STRIPE_PUBLISHABLE_KEY=

# ---- Stewardly missional/wealth integrations (from stewardly-ai) ----------
SNAPTRADE_CLIENT_ID=
SNAPTRADE_CONSUMER_KEY=
PLAID_CLIENT_ID=
PLAID_SECRET=
GHL_API_KEY=
GHL_WEBHOOK_SECRET=
GHL_LOCATION_ID=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
DEEPGRAM_API_KEY=
DAILY_API_KEY=
RESEND_API_KEY=
INTEGRATION_ENCRYPTION_KEY=
ALLOWED_ORIGINS=

# ---- Public-data integrations ---------------------------------------------
BEA_API_KEY=
BLS_API_KEY=
CENSUS_API_KEY=
FRED_API_KEY=

# ---- Stewardly v3 platform-level flags ------------------------------------
# Branding identifier, used in package metadata and emitted user-agent strings.
STEWARDLY_PLATFORM_ID=stewardly
# Engine module visibility (toggle individual engines off in dev/test).
STEWARDLY_ENGINE_FORMATIONAL=on
STEWARDLY_ENGINE_RELATIONAL=on
STEWARDLY_ENGINE_MISSIONAL=on
STEWARDLY_ENGINE_CONTEXTUAL=on
STEWARDLY_ENGINE_CONTINUOUS_IMPROVEMENT=on
# Default mission specialization for new advisor users (wealth | pastoral | ...).
STEWARDLY_DEFAULT_MISSION=wealth
# Conflict-of-interest architecture: pricing-markup percentage MUST be 0.
STEWARDLY_DIRECT_COST_MARKUP_PCT=0
# EMBA Section 7 ToS guard: hard block. NEVER set to "off" in production.
STEWARDLY_EMBA_GUARD=on
